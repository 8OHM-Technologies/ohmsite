APP_NAME=
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

# Admin
ADMIN_EMAIL="email@domain.com"
ADMIN_PASSWORD=secret_password

# Postgres Configuration (Production)
DB_CONNECTION=postgres
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=db
DB_USERNAME=admin
DB_PASSWORD=your_secure_password

# Redis Configuration (Performance Boost)
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

SESSION_DRIVER=redis
SESSION_LIFETIME=43200
SESSION_ENCRYPT=true
SESSION_SECURE_COOKIE=true

CACHE_STORE=redis
CACHE_PREFIX=8ohm.co.za_

QUEUE_CONNECTION=redis

# Filesystem
FILESYSTEM_DISK=public

# Email via Resend.com
MAIL_MAILER=resend
RESEND_API_KEY=re_123456789
MAIL_FROM_ADDRESS=
MAIL_FROM_NAME=

# Paystack
PAYSTACK_PUBLIC_KEY=
PAYSTACK_SECRET_KEY=

# Socialite
GITHUB_CLIENT_ID=client_id
GITHUB_CLIENT_SECRET=client_secret
GITHUB_REDIRECT_URL="${APP_URL}/auth/github/callback"

# Optimization
VITE_APP_NAME="${APP_URL}"

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=